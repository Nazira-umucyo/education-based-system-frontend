<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.nelly.education_based.LoginController"
           style="-fx-background-color: #1565C0;"
           prefWidth="420" prefHeight="520">

    <VBox alignment="CENTER" maxWidth="350">
        <!-- Card -->
        <VBox style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-padding: 36;
                     -fx-spacing: 14;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 24, 0, 0, 6);">

            <Label text="University Management System"
                   wrapText="true"
                   style="-fx-font-size: 19; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>

            <Label text="Education Portal — Sign In"
                   style="-fx-font-size: 12; -fx-text-fill: #757575;"/>

            <Separator/>

            <Label text="Username" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
            <TextField fx:id="usernameField"
                       promptText="Enter your username"
                       style="-fx-pref-height: 36; -fx-background-radius: 4;"/>

            <Label text="Password" style="-fx-font-weight: bold; -fx-font-size: 12;"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           style="-fx-pref-height: 36; -fx-background-radius: 4;"/>

            <Label fx:id="errorLabel"
                   text=""
                   wrapText="true"
                   style="-fx-text-fill: #C62828; -fx-font-size: 11;"/>

            <Button text="SIGN IN"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    style="-fx-background-color: #1565C0;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 13;
                           -fx-pref-height: 40;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;"/>

            <Label text="Default accounts:  admin / admin123   |   student / stud123"
                   wrapText="true"
                   style="-fx-font-size: 10; -fx-text-fill: #9E9E9E;" />
        </VBox>
    </VBox>
</StackPane>
